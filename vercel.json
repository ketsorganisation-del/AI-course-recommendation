{
  "version": 2,
  "builds": [
    {
      "src": "api/recommendations.js",
      "use": "@vercel/node"
    },
    {
      "src": "AI/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/get-python-recommendations",
      "dest": "AI/app/main.py"
    }
  ]
}